# Copy to docker.env and fill in values.
# docker.env is gitignored — never commit real secrets.

# Azure PostgreSQL
DATABASE_URL=postgres://user:password@your-server.postgres.database.azure.com:5432/dbname?sslmode=require
PS_DATABASE_URL=postgres://user:password@your-server.postgres.database.azure.com:5432/dbname?sslmode=require

# Redis — managed by docker compose; address is the service name
# Do not change unless running Redis outside Docker
REDIS_ADDR=redis:6379

# TDX API credentials
TDX_CLIENT_ID=your_tdx_client_id
TDX_CLIENT_SECRET=your_tdx_client_secret

# HuggingFace token — no longer required; embed service runs locally
# HF_TOKEN=hf_your_token_here

# Google Maps (if used by Flutter build, not needed server-side)
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Frontend (Flutter --dart-define)
# Used when building: flutter build apk --dart-define-from-file=../docker.env...
API_BASE_URL=http://your-server-ip:8080
POWERSYNC_URL=http://your-server-ip:8081
GRPC_HOST=your-server-ip
GRPC_PORT=50051
GRPC_TLS=false

# OSRM — filename of the pre-processed .osrm file inside ./osrm-data/
OSRM_FILE=taiwan.osrm

# TDX MQTT credentials (from TDX member centre → Data Services → Data Access Keys)
# Leave empty to skip MQTT subscriber
MQTT_CLIENT_ID=
MQTT_USERNAME=
MQTT_PASSWORD=
